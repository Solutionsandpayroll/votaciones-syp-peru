# Copia este archivo a .env y completa con tus valores reales

# URLs de Power Automate (ya no se usan activamente pero se conservan)
VITE_POWER_AUTOMATE_VOTE_ENDPOINT=TU_URL_DEL_FLUJO_DE_VOTACION_AQUI
VITE_POWER_AUTOMATE_CHECK_VOTER_ENDPOINT=TU_URL_DEL_FLUJO_DE_VERIFICACION_AQUI

# Neon PostgreSQL — connection string (SOLO para servidor, nunca llega al navegador)
DATABASE_URL=postgresql://usuario:password@host.neon.tech/neondb?sslmode=require

# Contraseña para acceder a la página de resultados
VITE_RESULTS_PASSWORD=TU_CONTRASENA_SEGURA_AQUI
